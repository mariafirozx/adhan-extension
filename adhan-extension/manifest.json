{
  "manifest_version": 3,
  "name": "Muslim Prayer Reminder",
  "version": "1.0",
  "description": "Get a heads-up 5 minutes before prayer, and again right when it's time, so you know when to take out your earphone and stop the music!",
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": ["https://api.aladhan.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
